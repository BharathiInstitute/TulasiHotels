rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if user is a super admin
    // Uses dynamic admins collection — no redeploy needed to add/remove admins
    // Falls back to primary owner emails for bootstrapping when collection is empty
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        || request.auth.token.email == 'kehsaram001@gmail.com'
        || request.auth.token.email == 'bharathiinstitute1@gmail.com'
      );
    }

    // Helper: check if auth user is an active member of a store
    function isMember(userId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(userId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(userId)/members/$(request.auth.uid)).data.status == 'active';
    }

    // Helper: check if auth user is the store creator (ownerUid field)
    function isStoreCreator(userId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(userId))
        && get(/databases/$(database)/documents/users/$(userId)).data.ownerUid == request.auth.uid;
    }

    // Helper: check if auth user is owner OR active member
    function isMemberOrOwner(userId) {
      return isOwner(userId) || isStoreCreator(userId) || isMember(userId);
    }

    // Helper: check if auth user is the owner or a manager-level member
    function isManagerOrOwner(userId) {
      return isOwner(userId) || isStoreCreator(userId) || (
        isMember(userId)
        && get(/databases/$(database)/documents/users/$(userId)/members/$(request.auth.uid)).data.role in ['owner', 'manager']
      );
    }

    // ── Subscription Limit Helpers ──
    // Read the user's limits from their root document
    function getUserLimits(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.limits;
    }

    // Check if user can create a bill (billsThisMonth < billsLimit)
    function canCreateBill(userId) {
      let limits = getUserLimits(userId);
      return limits.billsThisMonth < limits.billsLimit;
    }

    // Check if user can add a product (productsCount < productsLimit)
    function canAddProduct(userId) {
      let limits = getUserLimits(userId);
      return limits.productsCount < limits.productsLimit;
    }

    // Check if user can add a customer (customersCount < customersLimit)
    function canAddCustomer(userId) {
      let limits = getUserLimits(userId);
      // customersLimit must be initialized — deny if missing (prevents bypass)
      return 'customersLimit' in limits && limits.customersCount < limits.customersLimit;
    }

    // Check if user's subscription is active
    function hasActiveSubscription(userId) {
      let sub = get(/databases/$(database)/documents/users/$(userId)).data.subscription;
      return sub.status == 'active' || sub.status == 'trial';
    }

    // Rate limit: max writes per minute via last-write timestamp
    // Checks the user's `_lastWriteAt` field to enforce a cooldown.
    // Cloud Function `onBillCreated` updates this timestamp after each write.
    // Client-side throttle (ThrottleService) is the primary defense;
    // this rule is the server-side backstop.
    function isNotRateLimited(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      // If no timestamp yet, allow (first-time users)
      return !('_lastWriteAt' in userData)
          || request.time > userData._lastWriteAt + duration.value(1, 's');
    }
    
    // Helper function to validate required string field
    function hasString(field) {
      return field is string && field.size() > 0;
    }
    
    // Helper function to validate positive number
    function isPositive(value) {
      return value is number && value >= 0;
    }
    
    // Helper: limit document size (prevent abuse)
    function isReasonableSize() {
      return request.resource.size() < 500000; // 500KB max per document
    }
    
    // ===================
    // USER DOCUMENTS
    // ===================
    
    // Collection group rule: allows authenticated users to query ALL /members
    // sub-collections by email (used by resolvePendingInvites on login).
    // The read returns only docs where the caller's email matches — enforced
    // client-side via the .where() query; Firestore evaluates per-document.
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == memberId
            || resource.data.email == request.auth.token.email);
      allow write: if false; // writes handled by the specific sub-collection rule
    }

    match /users/{userId} {
      // Single document reads: owner, store creator, members, or admins
      allow get: if isAuthenticated() && (isOwner(userId) || isStoreCreator(userId) || isMember(userId) || isAdmin());
      // Collection queries (list): admins can list anything;
      // regular users can only query stores they own (where ownerUid == their UID).
      // This allows recoverOwnedHotels() to find hotels created by this user.
      allow list: if isAuthenticated() && (isAdmin() || resource.data.ownerUid == request.auth.uid);
      
      // Owner or store creator can write to their store doc
      allow write: if isAuthenticated() && (isOwner(userId) || isStoreCreator(userId)) && isReasonableSize();

      // Allow creating a NEW store doc if ownerUid matches the authenticated user
      allow create: if isAuthenticated() 
        && request.resource.data.ownerUid == request.auth.uid
        && isReasonableSize();
      
      // Admins can update user subscription/limits
      allow update: if isAdmin();
      
      // Don't allow deletion
      allow delete: if false;
      
      // ===================
      // SETTINGS (sub-collection for user preferences sync)
      // ===================
      match /settings/{settingId} {
        allow read: if isAuthenticated() && isMemberOrOwner(userId);
        allow write: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
      }
      
      // ===================
      // PRODUCTS (sub-collection)
      // Server-side limit: productsCount < productsLimit (from user doc)
      // Public read allowed for customer digital menu (/menu/:hotelId)
      // ===================
      match /products/{productId} {
        allow read: if true; // Public: customer menu browsing
        // CREATE: enforce subscription product limit
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && request.resource.data.name.size() <= 200
          && isPositive(request.resource.data.price)
          && request.resource.data.price <= 9999999
          && isReasonableSize()
          && canAddProduct(userId)
          && isNotRateLimited(userId);
        // UPDATE: no limit check needed (not creating new product)
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && request.resource.data.name.size() <= 200
          && isPositive(request.resource.data.price)
          && request.resource.data.price <= 9999999
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }
      
      // ===================
      // BILLS (sub-collection)
      // Server-side limit: billsThisMonth < billsLimit (from user doc)
      // ===================
      match /bills/{billId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        // Allow create with field validation AND subscription limit check
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.total is number
          && request.resource.data.total >= 0
          && request.resource.data.total <= 99999999
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 500
          && isReasonableSize()
          && canCreateBill(userId)
          && isNotRateLimited(userId);
        // Bills are immutable - no update
        allow update: if false;
        // Owner can delete for data retention/cleanup
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }
      
      // ===================
      // CUSTOMERS (sub-collection)
      // ===================
      match /customers/{customerId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && request.resource.data.name.size() <= 200
          && isReasonableSize()
          && canAddCustomer(userId)
          && isNotRateLimited(userId);
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && request.resource.data.name.size() <= 200
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
        
        // ===================
        // TRANSACTIONS (nested sub-collection under customers - legacy)
        // ===================
        match /transactions/{transactionId} {
          allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
          allow create: if isAuthenticated() && isMemberOrOwner(userId)
            && request.resource.data.amount is number
            && request.resource.data.amount > 0
            && request.resource.data.amount <= 99999999
            && isReasonableSize()
            && isNotRateLimited(userId);
          allow update: if false;
          allow delete: if isAuthenticated() && isMemberOrOwner(userId);
        }
      }
      
      // ===================
      // EXPENSES (sub-collection)
      // ===================
      match /expenses/{expenseId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 99999999
          && isReasonableSize()
          && isNotRateLimited(userId);
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 99999999
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }
      
      // ===================
      // TRANSACTIONS (direct sub-collection under user)
      // ===================
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 99999999
          && isReasonableSize()
          && isNotRateLimited(userId);
        // Transactions are immutable - no update
        allow update: if false;
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }
      
      // ===================
      // NOTIFICATIONS (sub-collection)
      // ===================
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow update: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow delete: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAdmin();
      }
      
      // ===================
      // ATTENDANCE (sub-collection)
      // ===================
      match /attendance/{attendanceId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId)
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }
      
      // ===================
      // SUBSCRIPTION AUDIT (admin-only audit trail)
      // ===================
      match /subscription_audit/{auditId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }

      // ===================
      // COUNTERS (sub-collection for atomic bill numbering etc.)
      // ===================
      match /counters/{counterId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow write: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
      }

      // ===================
      // TABLES (sub-collection for restaurant floor management)
      // ===================
      match /tables/{tableId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.number is int
          && request.resource.data.number >= 0
          && isReasonableSize()
          && isNotRateLimited(userId);
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // ORDERS (sub-collection for order lifecycle)
      // ===================
      match /orders/{orderId} {
        allow get: if true;
        allow list: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin())
          || (request.query.limit <= 10);
        allow create: if (isAuthenticated() && isMemberOrOwner(userId)
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 200
          && isReasonableSize()
          && isNotRateLimited(userId))
          || (request.resource.data.isCustomerOrder == true
          && request.resource.data.items is list
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 50
          && isReasonableSize());
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // STAFF (sub-collection for waiter/chef management)
      // ===================
      match /staff/{staffId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && request.resource.data.name.size() <= 200
          && isReasonableSize()
          && isNotRateLimited(userId);
        allow update: if isAuthenticated() && isMemberOrOwner(userId)
          && hasString(request.resource.data.name)
          && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // COMBOS (sub-collection for combo meals)
      // ===================
      match /combos/{comboId} {
        allow read: if true;
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // RESERVATIONS (sub-collection)
      // ===================
      match /reservations/{reservationId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isReasonableSize();
        allow update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // COUPONS (sub-collection)
      // ===================
      match /coupons/{couponId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // SHIFTS (sub-collection for staff scheduling)
      // ===================
      match /shifts/{shiftId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // TASKS (sub-collection for staff tasks)
      // ===================
      match /tasks/{taskId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // MESSAGES (sub-collection for staff communication)
      // ===================
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // CASH REGISTERS (sub-collection)
      // ===================
      match /cashRegisters/{registerId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // FEEDBACK (sub-collection)
      // ===================
      match /feedback/{feedbackId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isReasonableSize();
        allow update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // INGREDIENTS (sub-collection for inventory)
      // ===================
      match /ingredients/{ingredientId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // PURCHASES (sub-collection for inventory purchases)
      // ===================
      match /purchases/{purchaseId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // RECIPES (sub-collection)
      // ===================
      match /recipes/{recipeId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // VENDORS (sub-collection)
      // ===================
      match /vendors/{vendorId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // WASTAGE (sub-collection)
      // ===================
      match /wastage/{wastageId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow update: if false; // Wastage logs are immutable
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // LICENSES (sub-collection for compliance)
      // ===================
      match /licenses/{licenseId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // EQUIPMENT (sub-collection for maintenance tracking)
      // ===================
      match /equipment/{equipmentId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // COMPLAINTS (sub-collection)
      // ===================
      match /complaints/{complaintId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // EVENTS (sub-collection for banquet/event management)
      // ===================
      match /events/{eventId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // VENDOR PAYMENTS (sub-collection for vendor settlements)
      // ===================
      match /vendorPayments/{paymentId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create, update: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // VENDOR SETTLEMENTS (unified purchase + payment history)
      // ===================
      match /vendorSettlements/{settlementId} {
        allow read: if isAuthenticated() && (isMemberOrOwner(userId) || isAdmin());
        allow create: if isAuthenticated() && isMemberOrOwner(userId) && isReasonableSize();
        allow delete: if isAuthenticated() && isMemberOrOwner(userId);
      }

      // ===================
      // MEMBERS (sub-collection for multi-user store access)
      // ===================
      match /members/{memberId} {
        // Members can read their own doc directly; owners/managers/admins can read all
        allow read: if isAuthenticated() && (
          memberId == request.auth.uid
          || isMemberOrOwner(userId)
          || isAdmin()
        );
        allow create, update: if isAuthenticated() && isReasonableSize() && (
          isManagerOrOwner(userId)
          || get(/databases/$(database)/documents/users/$(userId)).data.ownerUid == request.auth.uid
          // Allow a member to create/migrate their own doc (invite resolution:
          // replaces placeholder UID with real UID when they first log in)
          || (memberId == request.auth.uid
              && request.resource.data.email == request.auth.token.email)
        );
        // Allow member to delete their own placeholder doc during invite resolution
        allow delete: if isAuthenticated() && (
          isMemberOrOwner(userId)
          || resource.data.email == request.auth.token.email
        );
      }
    }

    // ===================
    // USER HOTELS (maps users to their hotels)
    // User can read/write their own hotel list.
    // Any authenticated user can write to ANOTHER user's hotel list
    // (needed when owner adds a member — writes to user_hotels/{memberUid}/hotels)
    // ===================
    match /user_hotels/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
    }
    match /user_hotels/{userId}/hotels/{hotelId} {
      allow read: if isAuthenticated() && isOwner(userId);
      // Owner manages their own list; other authenticated users can add entries
      // (e.g. store owner linking a member to the store)
      allow create, update: if isAuthenticated() && isReasonableSize();
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // ===================
    // PENDING MEMBER INVITES
    // Written by store owners when inviting existing-account users.
    // Read by the invited user on login to resolve their membership.
    // ===================
    match /pending_member_invites/{inviteId} {
      allow create: if isAuthenticated() && isReasonableSize();
      // User can read/delete their own invites (queried by email)
      allow read, delete: if isAuthenticated()
        && resource.data.email == request.auth.token.email;
      // Allow listing so the query-by-email works
      allow list: if isAuthenticated();
      allow update: if false;
    }

    // ===================
    // ADMIN-ONLY COLLECTIONS
    // ===================
    match /_admin/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Legacy admin path
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // ===================
    // APP CONFIG (super admin management)
    // ===================
    match /app_config/{configId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // ===================
    // APP HEALTH & PERFORMANCE
    // Only authenticated users can submit; docs capped at 10KB to limit abuse
    // ===================
    match /app_health/{docId} {
      allow create: if isAuthenticated() && request.resource.size() < 10000;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /screen_performance/{docId} {
      allow create: if isAuthenticated() && request.resource.size() < 10000;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /network_metrics/{docId} {
      allow create: if isAuthenticated() && request.resource.size() < 10000;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /error_logs/{docId} {
      allow create: if isAuthenticated() && request.resource.size() < 10000;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
    
    match /error_logs_meta/{docId} {
      allow create, update: if isAuthenticated() && request.resource.size() < 5000;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ===================
    // GLOBAL NOTIFICATIONS (system-wide alerts)
    // Created by Cloud Functions or Admin panel, read by admins
    // ===================
    match /notifications/{notifId} {
      allow read: if isAdmin();
      // Admin can create/update from admin panel, Cloud Functions use Admin SDK
      allow write: if isAdmin();
    }
    
    // ===================
    // PAYMENT LINKS (created by Cloud Functions)
    // ===================
    match /payment_links/{linkId} {
      allow read: if isAdmin();
      // Cloud Functions create and update these via Admin SDK
      allow write: if false;
    }
    
    // ===================
    // ADMINS COLLECTION (used by Cloud Functions only)
    // ===================
    match /admins/{adminId} {
      allow read: if isAdmin();
      // Admins can create/update other admins
      allow create, update: if isAdmin();
      // Prevent deleting the primary owner admin (self-protection)
      // Only allow deletion if the target is not the requesting admin
      allow delete: if isAdmin() && adminId != request.auth.token.email;
    }
    
    // ===================
    // REGISTRATION OTPs (Cloud Functions only — no client access)
    // ===================
    match /registration_otps/{otpId} {
      allow read, write: if false;
    }
    
    // ===================
    // USER USAGE TRACKING (per-user backend cost tracking)
    // ===================
    match /user_usage/{userId} {
      // Users can read their own usage doc; admins can list/read all
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow list: if isAuthenticated() && isAdmin();
      // Users can write their own usage doc (for client-side tracking)
      // Admins can write any usage doc (for seeding / corrections)
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    // ===================
    // PAYMENT REQUESTS (for payment links)
    // ===================
    match /payment_requests/{requestId} {
      allow create: if isAuthenticated() && isReasonableSize();
      allow read: if isAuthenticated() && 
        (resource.data.createdBy == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ===================
    // SUPPORT TICKETS
    // ===================
    match /support_tickets/{ticketId} {
      // Users can read their own tickets, admins can read/list all
      allow get: if isAuthenticated() && 
        (resource.data.storeId == request.auth.uid || isAdmin());
      allow list: if isAuthenticated() && isAdmin();
      // Users can create tickets (storeId must match their uid)
      allow create: if isAuthenticated() 
        && request.resource.data.storeId == request.auth.uid
        && isReasonableSize();
      // Users can update their own tickets (e.g. close), admins can update any
      allow update: if isAuthenticated() && 
        (resource.data.storeId == request.auth.uid || isAdmin());
      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        // Users can read messages in their own tickets, admins can read all
        allow read: if isAuthenticated() && 
          (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.storeId == request.auth.uid || isAdmin());
        // Users can create messages in their own tickets, admins can create in any
        allow create: if isAuthenticated() && isReasonableSize() &&
          (get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.storeId == request.auth.uid || isAdmin());
        allow update: if false;
        allow delete: if false;
      }
    }
    
    // ===================
    // DESKTOP AUTH SESSIONS (for web-based desktop login flow)
    // These must be accessible BEFORE authentication (unauthenticated users)
    // Security: limited fields, small size, sessions are short-lived
    // ===================
    match /desktop_auth_sessions/{sessionId} {
      // Allow anyone to create a pending session (desktop app creates before auth)
      allow create: if request.resource.data.keys().hasOnly(['status', 'createdAt', 'expiresAt', 'deviceId'])
        && request.resource.data.status == 'pending'
        && request.resource.size() < 1000;
      
      // Allow reading session to poll for auth token
      // Note: sessionId acts as a secret — only the creator knows it
      allow read: if true;
      
      // Only authenticated users can update (web login page sets the token)
      // Cloud Functions also update via Admin SDK (bypasses rules)
      allow update: if isAuthenticated() && request.resource.size() < 5000;
      
      // Only authenticated users or admins can delete sessions
      allow delete: if isAuthenticated();
    }
    
    // ===================
    // REFERRAL REWARDS (created by Cloud Functions)
    // ===================
    match /referral_rewards/{rewardId} {
      allow read: if isAuthenticated() && resource.data.referrerId == request.auth.uid;
      allow write: if false;
    }

    // ===================
    // NPS SURVEYS (user satisfaction surveys)
    // ===================
    match /users/{userId}/surveys/{surveyId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
